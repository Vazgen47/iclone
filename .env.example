# IClone EVN Environment Variables Template
# Copy this to .env.local for local development
# Add these to Vercel Dashboard for production deployment

# ============================================
# TELEGRAM BOT CONFIGURATION
# ============================================
# Get these from @BotFather on Telegram
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_bot_token_here
NEXT_PUBLIC_TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Currency symbol for pricing display
NEXT_PUBLIC_CURRENCY_SYMBOL=֏

# ============================================
# OPTIONAL: IMAGE HOSTING
# ============================================
# If using external image hosting (optional)
NEXT_PUBLIC_IMAGE_DOMAIN=images.unsplash.com

# ============================================
# DEVELOPMENT ONLY
# ============================================
# These are not needed in production
# NEXT_PUBLIC_API_URL=http://localhost:3000

      "routeKeys": {
        "nxtPproductId": "nxtPproductId"
      },
      "namedRegex": "^/product/(?<nxtPproductId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/shop/[username]",
      "regex": "^/shop/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/shop/(?<nxtPusername>[^/]+?)(?:/)?$"
    }
  ],
